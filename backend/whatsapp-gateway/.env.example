APP_ENV=local

# Quarkus API. In local development, keep this as localhost.
QUARKUS_API_URL=http://localhost:8080

# Public URL used by Twilio to call this FastAPI service.
# Example with ngrok: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=

# Keep false while testing locally. Turn true when deployed with a stable public URL.
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_AUTH_TOKEN=

# Watson Assistant credentials from IBM Cloud.
WATSON_ENABLED=true
WATSON_API_KEY=
WATSON_URL=
WATSON_ASSISTANT_ID=
WATSON_ENVIRONMENT_ID=
WATSON_VERSION=2024-08-25

REQUEST_TIMEOUT_SECONDS=10
